   :body "//! Readiness event types and utilities.\n\n#[allow(clippy::module_inception)]\nmod event;\nmod events;\nmod source;\n\npub use self::event::Event;\npub use self::events::{Events, Iter};\npub use self::source::Source;\n"}])
