   :body "#![cfg(not(target_os = \"wasi\"))]\nuse std::io;\nuse std::net::{self, SocketAddr};\n\npub fn bind(_: SocketAddr) -> io::Result<net::UdpSocket> {\n    os_required!()\n}\n\npub(crate) fn only_v6(_: &net::UdpSocket) -> io::Result<bool> {\n    os_required!()\n}\n"} {:path "src/sys/unix/selector/epoll.rs"
   :sha256 "b952cb6d4225f442524d1a5a15bb7cecad6ad4738afaed5776e6b9d4a1203891"
